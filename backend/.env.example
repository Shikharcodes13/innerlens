PORT=4000

# Resend (HTTP email API) — SMTP is blocked outbound on Render's free tier, so email
# goes through this HTTPS API instead. Get an API key at https://resend.com/api-keys
RESEND_API_KEY=your-resend-api-key
# Must be a verified sending domain/address in Resend, or their shared test address below.
RESEND_FROM_EMAIL=InnerLens <onboarding@resend.dev>

# Twilio WhatsApp API
# Get Account SID / Auth Token from https://console.twilio.com
# TWILIO_WHATSAPP_FROM is the Sandbox number (whatsapp:+14155238886) until you have an approved sender.
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Optional: Twilio Content Template SID for the one-time report send, once approved.
# Leave blank to use a freeform message (works on the Sandbox).
WHATSAPP_REPORT_CONTENT_SID=

# This backend's own public HTTPS base URL — Twilio fetches PDF/video media from here,
# so it must be reachable from the internet (Render deploy URL, or an ngrok tunnel locally).
BACKEND_PUBLIC_URL=http://localhost:4000

# Used in email referral copy
APP_PUBLIC_URL=http://localhost:5173
