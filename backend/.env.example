PORT=4000

# SMTP (Nodemailer) - e.g. Gmail with an App Password (not your regular password)
# Create one at https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password

# Meta WhatsApp Cloud API (free test mode)
# Get these from https://developers.facebook.com -> your app -> WhatsApp -> API Setup
WHATSAPP_TOKEN=your-temporary-test-access-token
WHATSAPP_PHONE_NUMBER_ID=your-test-phone-number-id

# Used in email referral copy
APP_PUBLIC_URL=http://localhost:5173
